{
  "permissions": {
    "allow": [
      "Bash(python3 -m pip --version)",
      "Bash(python3 -m venv .venv)",
      "Bash(.venv/bin/pip install *)",
      "Bash(.venv/bin/python -c \"import flask, bcrypt, dotenv; print\\('flask', flask.__version__\\); print\\('bcrypt', bcrypt.__version__\\); print\\('dotenv ok'\\)\")",
      "Bash(curl -s -o /dev/null -w '%{http_code}' http://127.0.0.1:5000/login)",
      "Bash(curl -s -o /dev/null -w 'status: %{http_code}\\\\n' http://127.0.0.1:5000/login)",
      "Bash(curl -s -o /dev/null -w 'status: %{http_code}, redirect: %{redirect_url}\\\\n' http://127.0.0.1:5000/dashboard)",
      "Bash(curl -s -o /dev/null -w 'status: %{http_code}, redirect: %{redirect_url}\\\\n' http://127.0.0.1:5000/admin/users)",
      "Bash(curl -s -o /dev/null -w 'status: %{http_code}, redirect: %{redirect_url}\\\\n' http://127.0.0.1:5000/)",
      "Bash(curl -s -o /dev/null -w 'status: %{http_code}\\\\n' -H \"X-Forwarded-For: 8.8.8.8\" http://127.0.0.1:5000/login)"
    ]
  }
}
