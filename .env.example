SECRET_KEY=change-me-to-a-long-random-string
MAX_UPLOAD_MB=50

# Comma-separated list of allowed network prefixes. Requests from other IPs are rejected.
# Examples:
#   127.0.0.1,::1                       (localhost only — default for dev)
#   192.168.1.,10.0.0.                  (your LAN subnets)
ALLOWED_IP_PREFIXES=127.0.0.1,::1
